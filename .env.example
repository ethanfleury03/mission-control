# Next.js app port (npm run dev / npm start use port 3002 — see package.json)
# PORT=3002
# Cloud Run sets PORT (often 8080); `next start` is not used in the production Dockerfile (standalone server.js reads PORT).

# NextAuth — required in production. For local dev, `auth.ts` uses a dev-only default if unset;
# for production / shared environments set a real value: `openssl rand -base64 32`
# AUTH_SECRET=
# NEXTAUTH_URL=https://support.arrsys.com
# Google OAuth for NextAuth
# AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
# Optional local/testing auth bypass. This is ignored in production by code.
# Do not enable in shared or hosted environments.
# AUTH_BYPASS_LOGIN=1
# AUTH_BYPASS_EMAIL=dev@arrsys.com

# Blogs are hidden by default in production deploys for the rep launch surface.
# Set both flags to true only if the blogs workflow is intentionally enabled.
# ENABLE_BLOGS=false
# NEXT_PUBLIC_ENABLE_BLOGS=false

# Gateway URL for the optional OpenClaw hub. Leave unset in production unless you
# have a separately deployed gateway service.
# Default local dev fallback: http://localhost:18792
NEXT_PUBLIC_GATEWAY_URL=http://localhost:18792

# Backend Mission Control API (Express in /server). Required for org proxy routes and API rewrites.
# On Cloud Run, set to the public URL of the API service (or internal URL if using a VPC connector + internal LB).
# API_URL=https://your-mc-api-xxx.run.app
# NEXT_PUBLIC_API_URL=https://your-mc-api-xxx.run.app
# MISSION_CONTROL_API_URL=https://your-mc-api-xxx.run.app

# Set to 1 to disable OpenClaw hub polling (eliminates log spam and slow requests when openclaw isn't running)
# DISABLE_OPENCLAW=1
# When unset, you can still toggle hub polling from the Arrow Hub header ("OpenClaw hub on/off") — uses a browser cookie.

# Prisma CLI (db push / migrate dev) uses this local SQLite file. It is not used at runtime when Turso is configured.
DATABASE_URL="file:./prisma/dev.db"
# Optional: hosted SQLite on Turso — same DB for every machine. When set, the app uses LibSQL at runtime (see lib/prisma.ts).
# Leave unset for local-file SQLite (CI, offline) or when only running Prisma CLI against dev.db.
# TURSO_DATABASE_URL=libsql://your-db-name-<org>.turso.io
# TURSO_AUTH_TOKEN=your-auth-token-here
# After pulling schema changes: `npm run db:push` locally, then apply generated migration SQL to Turso (`turso db shell …`; see README).
# Without Turso: the SQLite file is gitignored — after clone, run `npm run db:push && npm run db:seed` for Lead Gen demo markets.

# Optional: Playwright Chromium path (production or custom install)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: Google Sheets export (service account)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Directory Scraper AI extraction (OpenRouter — recommended for reliable company-name extraction)
# Without this key the scraper falls back to deterministic heuristics (works for tables/JSON-LD,
# but struggles with prose member lists like association homepages).
# Get a key at https://openrouter.ai — enable "AI extraction" checkbox in the UI.
# OPENROUTER_API_KEY=sk-or-...
# DIRECTORY_SCRAPER_AI_MODEL=openai/gpt-4o-mini   # any OpenRouter model slug; must support JSON output
# Separate OpenRouter key for Image Studio so usage/cost can be tracked independently.
# IMAGE_OPENROUTER_API_KEY=sk-or-...
# IMAGE_OPENROUTER_CHAT_MODEL=deepseek/deepseek-chat-v3.1
# IMAGE_OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
# IMAGE_OPENROUTER_VIDEO_MODEL=google/veo-3.1-fast

# Optional: Firecrawl for page fetch (clean markdown; UI "Firecrawl" mode). Self-host: FIRECRAWL_BASE_URL=https://your-host/v1
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_BASE_URL=

# Phone / cold calling (Retell-backed)
# RETELL_API_KEY=
# Optional explicit Phone profile override values. If unset, Phone uses the current Arrow demo defaults.
# PHONE_RETELL_PROFILE_KEY=arrow-demo-v2
# PHONE_RETELL_PROFILE_LABEL=Arrow Cold Call Demo
# PHONE_RETELL_AGENT_ID=
# PHONE_RETELL_CONVERSATION_FLOW_ID=
# PHONE_RETELL_OUTBOUND_NUMBER=
# PHONE_RETELL_OUTBOUND_NUMBER_LABEL=Locked Retell outbound number
# PHONE_RETELL_VOICE_LABEL=11labs-Adrian · eleven_turbo_v2
# PHONE_RETELL_WEBHOOK_STATUS=Configured
# PHONE_WORKER_POLL_MS=5000

# Optional: Serper.dev — cheap Google search for “Find company websites” after name extraction
# Sign up at https://serper.dev — one search per company without a website (after free domain guesses).
# SERPER_API_KEY=
# Optional self-host / alternate endpoint (default https://google.serper.dev)
# SERPER_BASE_URL=
