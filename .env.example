# Gateway URL for Mission Control API (used by Kanban, registry, etc.)
# Default: http://localhost:18792
NEXT_PUBLIC_GATEWAY_URL=http://localhost:18792

# Optional: n8n blog pipeline — when set, Blogs "Start" / "Retry" POST here instead of OpenClaw
# N8N_BLOG_WEBHOOK_URL=https://your-n8n.example/webhook/blog-run
# N8N_BLOG_WEBHOOK_SECRET=
# Public origin of this Next app (for callback URL in webhook payload)
# NEXT_PUBLIC_APP_URL=https://mission-control.example
# Require secret on POST /api/blogs/handoff (n8n HTTP Request node)
# BLOG_HANDOFF_SECRET=
