# Gateway URL for Mission Control API (used by Kanban, registry, etc.)
# Default: http://localhost:18792
NEXT_PUBLIC_GATEWAY_URL=http://localhost:18792

# Set to 1 to disable OpenClaw hub polling (eliminates log spam and slow requests when openclaw isn't running)
# DISABLE_OPENCLAW=1

# Prisma / Directory Scraper persistence (SQLite file — use postgres:// for Postgres)
DATABASE_URL="file:./prisma/dev.db"

# Optional: Playwright Chromium path (production or custom install)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: Google Sheets export (service account)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Directory Scraper AI extraction (OpenRouter — recommended for reliable company-name extraction)
# Without this key the scraper falls back to deterministic heuristics (works for tables/JSON-LD,
# but struggles with prose member lists like association homepages).
# Get a key at https://openrouter.ai — enable "AI extraction" checkbox in the UI.
# OPENROUTER_API_KEY=sk-or-...
# DIRECTORY_SCRAPER_AI_MODEL=openai/gpt-4o-mini   # any OpenRouter model slug; must support JSON output

# Optional: Firecrawl for page fetch (clean markdown; UI "Firecrawl" mode). Self-host: FIRECRAWL_BASE_URL=https://your-host/v1
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_BASE_URL=

# Optional: Serper.dev — cheap Google search for “Find company websites” after name extraction
# Sign up at https://serper.dev — one search per company without a website (after free domain guesses).
# SERPER_API_KEY=
# Optional self-host / alternate endpoint (default https://google.serper.dev)
# SERPER_BASE_URL=
