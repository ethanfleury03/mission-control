// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // bookworm-slim (Cloud Run image) uses OpenSSL 3; include engine for Linux prod builds.
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Organization Departments
model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  people Person[]

  @@map("departments")
}

// Organization People/Employees
model Person {
  id        String   @id @default(uuid())
  name      String
  role      String
  email     String?
  level     Int      @default(1)
  status    String   @default("active") // active, inactive, pending
  type      String   @default("leaf")   // root, leaf, manager
  avatar    String?
  permissions String? // JSON array stored as string
  profileFile String?

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Hierarchy - Self-referential relations
  managerId   String?
  manager     Person?  @relation("Manages", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Person[] @relation("Manages")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Org Chart Position (for visual layout)
  posX      Float?   @default(0)
  posY      Float?   @default(0)

  // Events/Changes tracking
  events    OrgEvent[]

  @@map("people")
}

// Organization Events - Track changes for incremental updates
model OrgEvent {
  id        String   @id @default(uuid())
  type      String   // create, update, delete, move, promote, demote
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  // Change details
  field     String?  // Which field changed (for updates)
  oldValue  String?  // JSON string of old value
  newValue  String?  // JSON string of new value

  // Context
  metadata  String?  // JSON string with additional context

  createdAt DateTime @default(now())

  @@index([personId])
  @@index([createdAt])
  @@map("org_events")
}

// Snapshots for versioning
model OrgSnapshot {
  id          String   @id @default(uuid())
  name        String
  description String?
  data        String   // JSON string of full org chart state
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@map("org_snapshots")
}

model AppUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("")
  image        String   @default("")
  googleSub    String   @unique
  hostedDomain String   @default("")
  status       String   @default("active")
  role         String   @default("user")
  loginCount   Int      @default(0)
  lastLoginAt  DateTime @default(now())
  lastSeenAt   DateTime?
  lastLoginIp  String   @default("")
  lastUserAgent String  @default("")
  disabledAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([hostedDomain])
  @@index([status])
  @@index([role])
  @@map("app_users")
}

model AuthEventLog {
  id          String   @id @default(cuid())
  type        String
  actorEmail  String   @default("")
  targetEmail String   @default("")
  ip          String   @default("")
  userAgent   String   @default("")
  route       String   @default("")
  action      String   @default("")
  detailJson  String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([actorEmail])
  @@index([targetEmail])
  @@index([createdAt])
  @@map("auth_event_logs")
}

// Directory Scraper — persisted jobs (SQLite today; swap DATABASE_URL for Postgres later)
model DirectoryScrapeJob {
  id         String    @id @default(uuid())
  status     String    // queued | running | cancelled | completed | failed
  phase      String    @default("queued") // queued | extracting_names | discovering_websites | enriching | exporting_optional | completed | failed | cancelled
  inputJson  String    // ScrapeJobInput JSON
  progressJson String  @default("{}") // JobProgress JSON
  attemptCount Int     @default(0)
  maxAttempts Int      @default(3)
  queuedAt   DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  heartbeatAt DateTime?
  leaseOwner String?
  leaseExpiresAt DateTime?
  nextRetryAt DateTime?
  cancelRequestedAt DateTime?
  errorCode  String?
  errorMessage String?
  summaryJson String   // JobSummary JSON
  metaJson   String    @default("{}") // JobMeta JSON (duration, last company, export counts)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  results DirectoryScrapeResult[]
  logs    DirectoryScrapeLog[]

  @@index([createdAt])
  @@index([status])
  @@index([status, leaseExpiresAt])
  @@index([nextRetryAt])
  @@index([phase])
  @@map("directory_scrape_jobs")
}

model DirectoryScrapeResult {
  id                  String   @id @default(uuid())
  jobId               String
  job                 DirectoryScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  companyName         String
  directoryListingUrl String
  companyWebsite      String   @default("")
  contactName         String   @default("")
  email               String   @default("")
  phone               String   @default("")
  address             String   @default("")
  contactPageUrl      String   @default("")
  socialLinks         String   @default("")
  notes               String   @default("")
  confidence          String   // high | medium | low
  status              String   // pending | scraping | enriching | done | failed
  error               String?
  rawContactJson      String?  // ContactInfo JSON
  nameExtractionMetaJson String? // Name-extraction pipeline debug JSON
  websiteDiscoveryMetaJson String? // Serper / domain-guess website resolution audit JSON
  needsReview         Boolean  @default(false)
  sortOrder           Int      @default(0)

  @@index([jobId])
  @@index([jobId, status])
  @@map("directory_scrape_results")
}

model DirectoryScrapeLog {
  id        String   @id @default(uuid())
  jobId     String
  job       DirectoryScrapeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  level     String   // info | warn | error
  phase     String?
  eventCode String?
  message   String

  @@index([jobId])
  @@index([jobId, timestamp])
  @@map("directory_scrape_logs")
}

// --- Lead Generation (markets + accounts; directory scraper can import into accounts) ---

model LeadGenMarket {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String   @default("")
  countriesJson    String   @default("[]") // JSON string array
  personasJson     String   @default("[]") // target personas
  solutionAreasJson String  @default("[]")
  status           String   @default("active") // active | building | planned | archived
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts LeadGenAccount[]

  @@index([status])
  @@map("lead_gen_markets")
}

model LeadGenAccount {
  id                  String    @id @default(cuid())
  marketId            String
  market              LeadGenMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)

  name                String
  normalizedName      String    @default("")
  domain              String    @default("")
  normalizedDomain    String    @default("")
  website             String    @default("")
  email               String    @default("")
  phone               String    @default("")
  country             String    @default("Unknown")
  region              String    @default("")
  industry            String    @default("")
  subindustry         String    @default("")
  companySizeBand     String    @default("unknown")
  revenueBand         String    @default("unknown")
  description         String    @default("")

  sourceType          String    @default("demo")
  sourceName          String    @default("")
  sourceUrl           String    @default("")
  directoryJobId      String?
  directoryResultId   String?

  status              String    @default("prospect")
  fitScore            Int       @default(0)
  fitSummary          String    @default("")
  assignedOwner       String    @default("")
  reviewState         String    @default("new")
  // leadPipelineStage: discovered | triaged_ok | triaged_hold | rejected | pushed_to_hubspot | push_failed
  leadPipelineStage   String    @default("discovered")

  hubspotContactId    String?
  hubspotPushedAt     DateTime?
  hubspotPushedBy     String    @default("")
  hubspotLastPushError String  @default("")

  lastSeenAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([marketId])
  @@index([marketId, reviewState])
  @@index([marketId, normalizedDomain])
  @@index([marketId, normalizedName, country])
  @@index([directoryJobId, directoryResultId])
  @@map("lead_gen_accounts")
}

model LeadGenIngestionEvent {
  id                 String   @id @default(cuid())
  marketId           String
  accountId          String?
  directoryJobId     String
  directoryResultId  String
  mergeOutcome       String   // created | updated | skipped_duplicate | conflict | error
  conflictFieldsJson String   @default("[]")
  detailsJson        String   @default("{}")
  createdAt          DateTime @default(now())

  @@index([marketId, createdAt])
  @@index([accountId, createdAt])
  @@index([directoryJobId, directoryResultId])
  @@map("lead_gen_ingestion_events")
}

// --- Geo Intelligence (dealer network + HubSpot contact coverage snapshot) ---

model GeoDealer {
  id            String   @id @default(cuid())
  name          String
  addressLine1  String
  addressLine2  String   @default("")
  city          String   @default("")
  stateRegion   String   @default("")
  postalCode    String   @default("")
  country       String
  countryCode   String   @default("")
  countryIsoA3  String   @default("")
  lat           Float
  lng           Float
  status        String   @default("active")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([countryIsoA3])
  @@map("geo_dealers")
}

model GeoHubSpotContactSnapshot {
  id               String    @id @default(cuid())
  hubspotContactId String    @unique
  firstName        String    @default("")
  lastName         String    @default("")
  email            String    @default("")
  country          String    @default("")
  countryCode      String    @default("")
  countryIsoA3     String    @default("")
  stateRegion      String    @default("")
  stateCode        String    @default("")
  stateKey         String    @default("")
  city             String    @default("")
  ownerId          String    @default("")
  ownerName        String    @default("")
  lifecycleStage   String    @default("")
  leadStatus       String    @default("")
  persona          String    @default("")
  isMappable       Boolean   @default(false)
  sourceUpdatedAt  DateTime?
  lastSyncedAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([countryIsoA3])
  @@index([countryIsoA3, stateKey])
  @@index([ownerId])
  @@index([lifecycleStage])
  @@index([leadStatus])
  @@index([persona])
  @@index([isMappable])
  @@map("geo_hubspot_contact_snapshots")
}

model GeoSyncState {
  id                 String    @id
  status             String    @default("idle")
  lastAttemptedAt    DateTime?
  lastSyncedAt       DateTime?
  lastError          String    @default("")
  totalRecords       Int       @default(0)
  mappableRecords    Int       @default(0)
  unmappableRecords  Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("geo_sync_state")
}

// --- Phone / Cold Calling ---------------------------------------------------

model PhoneList {
  id                String   @id @default(cuid())
  sourceType        String   @default("manual")
  displayName       String
  notes             String   @default("")
  status            String   @default("active")
  sourceMetadataJson String  @default("{}")
  totalEntries      Int      @default(0)
  dialableEntries   Int      @default(0)
  invalidEntries    Int      @default(0)
  duplicateEntries  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  entries   PhoneListEntry[]
  campaigns PhoneCampaign[]
  calls     PhoneCall[]

  @@index([status])
  @@index([sourceType])
  @@map("phone_lists")
}

model PhoneListEntry {
  id               String   @id @default(cuid())
  listId           String
  list             PhoneList @relation(fields: [listId], references: [id], onDelete: Cascade)
  companyName      String   @default("")
  contactName      String   @default("")
  title            String   @default("")
  phoneRaw         String   @default("")
  phoneNormalized  String   @default("")
  email            String   @default("")
  website          String   @default("")
  country          String   @default("")
  timezone         String   @default("")
  notes            String   @default("")
  sourceMetadataJson String @default("{}")
  sourceExternalId String?
  queueState       String   @default("ready")
  duplicateWithinList Boolean @default(false)
  attempts         Int      @default(0)
  lastOutcome      String   @default("unknown")
  lastCallAt       DateTime?
  retryAfter       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  calls PhoneCall[]

  @@index([listId])
  @@index([listId, phoneNormalized])
  @@index([queueState, retryAfter])
  @@index([lastCallAt])
  @@map("phone_list_entries")
}

model PhoneCampaign {
  id              String   @id @default(cuid())
  listId          String
  list            PhoneList @relation(fields: [listId], references: [id], onDelete: Cascade)
  name            String
  agentProfileKey String
  settingsJson    String   @default("{}")
  status          String   @default("draft")
  startedAt       DateTime?
  pausedAt        DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  lastRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  calls PhoneCall[]

  @@index([status])
  @@index([listId])
  @@map("phone_campaigns")
}

model PhoneCall {
  id                 String   @id @default(cuid())
  campaignId         String?
  campaign           PhoneCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  listId             String?
  list               PhoneList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  listEntryId        String?
  listEntry          PhoneListEntry? @relation(fields: [listEntryId], references: [id], onDelete: SetNull)
  providerCallId     String   @unique
  agentProfileKey    String   @default("")
  providerStatus     String   @default("registered")
  disposition        String   @default("unknown")
  bookedFlag         Boolean  @default(false)
  summary            String   @default("")
  transcript         String   @default("")
  recordingUrl       String   @default("")
  disconnectionReason String  @default("")
  dynamicVariablesJson String @default("{}")
  metadataJson       String   @default("{}")
  analysisJson       String   @default("{}")
  rawPayloadJson     String   @default("{}")
  startedAt          DateTime?
  endedAt            DateTime?
  durationMs         Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  events PhoneCallEvent[]

  @@index([campaignId])
  @@index([listId])
  @@index([listEntryId])
  @@index([providerStatus])
  @@index([disposition])
  @@index([startedAt])
  @@index([createdAt])
  @@map("phone_calls")
}

model PhoneCallEvent {
  id          String   @id @default(cuid())
  phoneCallId String
  phoneCall   PhoneCall @relation(fields: [phoneCallId], references: [id], onDelete: Cascade)
  eventType   String
  payloadJson String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([phoneCallId, createdAt])
  @@map("phone_call_events")
}

model PhoneSettings {
  id                            String   @id @default("default")
  defaultTimezone               String   @default("America/New_York")
  businessHoursStart            String   @default("09:00")
  businessHoursEnd              String   @default("17:00")
  activeWeekdaysJson            String   @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\"]")
  dailyCallCap                  Int      @default(50)
  cooldownSeconds               Int      @default(45)
  maxAttemptsPerLead            Int      @default(3)
  retryDelayMinutes             Int      @default(240)
  voicemailEnabled              Boolean  @default(true)
  autoPauseAfterRepeatedFailures Boolean @default(true)
  defaultSourceBehavior         String   @default("retain_duplicates_mark_invalid")
  lastRetellSyncAt              DateTime?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@map("phone_settings")
}

model ImageGenerationSettings {
  id                String   @id @default("default")
  provider          String   @default("openrouter")
  orchestratorModel String   @default("deepseek/deepseek-chat-v3.1")
  promptsJson       String   @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("image_generation_settings")
}

model ImageGenerationRun {
  id               String   @id @default(cuid())
  userPrompt       String   @default("")
  assistantReply   String   @default("")
  plannerJson      String   @default("{}")
  finalImagePrompt String   @default("")
  chatModel        String   @default("")
  imageModel       String   @default("")
  machineId        String?
  imageType        String   @default("linkedin_ad")
  imageDataUrl     String   @default("")
  imageMimeType    String   @default("image/png")
  imageAlt         String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@map("image_generation_runs")
}

model ImageGenerationVideoRun {
  id                  String   @id @default(cuid())
  userPrompt          String   @default("")
  assistantReply      String   @default("")
  sourceKind          String
  sourceImageRunId    String?
  sourceImageFileName String
  sourceImageMimeType String
  sourceImageByteSize Int
  sourceImageBytes    Bytes
  videoModel          String   @default("")
  openrouterJobId     String   @default("")
  openrouterGenerationId String?
  status              String   @default("pending")
  errorMessage        String?
  durationSeconds     Int
  resolution          String   @default("720p")
  aspectRatio         String   @default("16:9")
  videoFileName       String?
  videoMimeType       String?
  videoByteSize       Int?
  videoBytes          Bytes?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([openrouterJobId])
  @@map("image_generation_video_runs")
}

model ImageGenerationMachine {
  id               String                       @id @default(cuid())
  title            String
  notes            String                       @default("")
  brochureFilename String?
  brochureMimeType String?
  brochureByteSize Int?
  brochurePdf      Bytes?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  images           ImageGenerationMachineImage[]

  @@index([title])
  @@index([updatedAt])
  @@map("image_generation_machines")
}

model ImageGenerationMachineImage {
  id         String   @id @default(cuid())
  machineId   String
  machine     ImageGenerationMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  label      String   @default("Reference image")
  fileName   String
  mimeType   String
  byteSize   Int
  imageBytes Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([machineId])
  @@index([updatedAt])
  @@map("image_generation_machine_images")
}

model ImageGenerationKBAsset {
  id         String   @id @default(cuid())
  category   String
  label      String
  fileName   String
  mimeType   String
  byteSize   Int
  imageBytes Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([updatedAt])
  @@map("image_generation_kb_assets")
}

model ImageGenerationKBColor {
  id         String   @id @default(cuid())
  name       String
  hex        String
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
  @@map("image_generation_kb_colors")
}

model Manual {
  id        String   @id @default(cuid())
  name      String
  fileName  String
  mimeType  String
  byteSize  Int
  fileBytes Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
  @@map("manuals")
}
